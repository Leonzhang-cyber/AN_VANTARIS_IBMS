# Local DB smoke profile (example only — do not commit as .env)
#
# Copy selected lines into a gitignored .env for manual local smoke runs.
# Never commit real secrets or generated JWT tokens.

# Return stable fixture data for read-only system smoke routes (JWT still required).
IBMS_LOCAL_SMOKE=true

# Optional overrides (defaults shown in src/common/config/default.py / .env.example)
# IBMS_DB_HOST=127.0.0.1
# IBMS_DB_PORT=3306
# IBMS_DB_NAME=ibms_db
# IBMS_DB_USER=ibms_user
# IBMS_DB_PASSWORD=replace-with-db-password

# Dev JWT signing uses IBMS_JWT_SECRET from environment or development fallback in default.py.
# IBMS_JWT_SECRET=replace-with-random-jwt-secret
