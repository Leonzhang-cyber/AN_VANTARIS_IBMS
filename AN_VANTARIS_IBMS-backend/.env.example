# VANTARIS IBMS Backend Environment Example
# Copy this file to .env and replace placeholder values.
# Never commit real .env files.
# SECURITY-A5B: default.py / blockchain/config.py dev fallbacks use placeholders only;
# export these variables (or copy to gitignored .env) for local DID, DB, MQTT, and blockchain use.

IBMS_ENV=development
IBMS_DEBUG=false

# Local smoke (BACKEND-SMOKE-UNBLOCK-EXEC) — export before start; do not commit real .env
# IBMS_ENV=local-smoke
# IBMS_BIND_HOST=127.0.0.1
# IBMS_BIND_PORT=5001
# Skips blockchain init and IoT DeviceManager; uses dev JWT/DB fallbacks from default.py
# Install: pip install -r requirements-macos-smoke.txt (Python >=3.10)
# Run: cd AN_VANTARIS_IBMS-backend && IBMS_ENV=local-smoke PYTHONPATH=. python src/main.py

# Flask / App (SECURITY-A2: read at runtime when exported or loaded into environment)
# Production must set both — do not rely on development fallbacks in default.py
IBMS_SECRET_KEY=replace-with-random-secret-key
IBMS_JWT_SECRET=replace-with-random-jwt-secret

# Database (SECURITY-A3: read at runtime when exported — production required)
IBMS_DATABASE_URL=mysql+pymysql://ibms_user:replace-password@127.0.0.1:3306/ibms_db
IBMS_DB_HOST=127.0.0.1
IBMS_DB_PORT=3306
IBMS_DB_NAME=ibms_db
IBMS_DB_USER=ibms_user
IBMS_DB_PASSWORD=replace-with-db-password

# MQTT (SECURITY-A4: read at runtime when exported — production required)
IBMS_MQTT_HOST=127.0.0.1
IBMS_MQTT_PORT=1883
IBMS_MQTT_USERNAME=replace-with-mqtt-user
IBMS_MQTT_PASSWORD=replace-with-mqtt-password

# DID / Blockchain (SECURITY-A5: read at runtime when exported — production required)
# IBMS_BLOCKCHAIN_RPC_URL accepts comma-separated URLs for multi-node setups
IBMS_DID_PRIVATE_KEY=replace-with-did-private-key
IBMS_BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
IBMS_BLOCKCHAIN_CHAIN_ID=9527
IBMS_BLOCKCHAIN_CONTRACT_ADDRESS=replace-with-contract-address

# Test-only (SECURITY-A5C: manual test scripts — placeholder only, never commit real keys)
IBMS_TEST_DID_PRIVATE_KEY=replace-with-test-did-private-key

# Feature Flags (SECURITY-A8: simulators/testMQTT disabled in production; explicit enable in dev)
# IBMS_ENV=production forces IBMS_SIMULATOR_ENABLED and IBMS_TESTMQTT_ENABLED off regardless of values below.
IBMS_SIMULATOR_ENABLED=false
IBMS_MODELING_API_ENABLED=false
IBMS_TESTMQTT_ENABLED=false

# Storage / Files
IBMS_UPLOAD_DIR=uploads
IBMS_MAX_UPLOAD_MB=20

# Audit / Trace
IBMS_TRACE_ENABLED=true
IBMS_AUDIT_ENABLED=true
