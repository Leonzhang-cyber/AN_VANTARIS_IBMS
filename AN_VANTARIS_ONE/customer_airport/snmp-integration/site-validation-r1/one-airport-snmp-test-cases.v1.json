{
  "schemaVersion": "1.0",
  "testCaseMatrixId": "one-airport-snmp-test-cases-r1",
  "scope": "Unified SNMP site validation test cases for DTS4160, BHE BRTL32, and NEC PABX.",
  "testCases": [
    {
      "testId": "DTS-SNMP-R1-001",
      "system": "DTS4160",
      "name": "DTS alarm OID normal polling",
      "oidOrTrapName": "1.3.6.1.4.1.13842.4.4160.1.8",
      "objective": "Capture normal/clear alarm mask sample.",
      "expectedSample": "00000000.00000000",
      "expectedOneEvent": "DTS4160_ALARM_MASK_CLEARED",
      "expectedRoute": ["ONE Alarm Console", "Evidence / Reports"],
      "evidenceRequired": ["snmpget output", "timestamp", "device identity"],
      "status": "pendingSiteValidation"
    },
    {
      "testId": "DTS-SNMP-R1-002",
      "system": "DTS4160",
      "name": "DTS alarm OID active polling",
      "oidOrTrapName": "1.3.6.1.4.1.13842.4.4160.1.8",
      "objective": "Capture active alarm mask sample and confirm controlled labels.",
      "expectedSample": "00408080.00000000",
      "expectedDecodedLabels": ["GNSS Sync Lost", "No valid Time Source", "No DTS Link"],
      "expectedOneEvent": "DTS4160_TIME_SYNC_ALARM_ACTIVE",
      "expectedRoute": ["ONE Alarm Console", "Fault Operations", "Work Management / MMS", "Evidence / Reports"],
      "evidenceRequired": ["snmpget output", "vendor/customer observation", "timestamp"],
      "status": "pendingSiteValidation"
    },
    {
      "testId": "DTS-SNMP-R1-003",
      "system": "DTS4160",
      "name": "DTS alarm clear validation",
      "oidOrTrapName": "1.3.6.1.4.1.13842.4.4160.1.8",
      "objective": "Confirm active-to-clear stability.",
      "expectedOneEvent": "DTS4160_ALARM_CLEAR",
      "expectedRoute": ["ONE Alarm Console", "Evidence / Reports"],
      "evidenceRequired": ["active sample", "clear sample", "correlation timestamp"],
      "status": "pendingSiteValidation"
    },
    {
      "testId": "DTS-SNMP-R1-004",
      "system": "DTS4160",
      "name": "DTS communication loss",
