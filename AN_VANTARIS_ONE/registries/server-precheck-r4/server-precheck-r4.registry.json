{
  "taskId": "SERVER-PRECHECK-R4",
  "scope": "SERVER_PRECHECK_R4",
  "moduleId": "server-precheck-r4-readonly-ssh-execution-approval-packet",
  "mode": "read-only approval packet",
  "passMarker": "ONE_SERVER_PRECHECK_R4_READONLY_SSH_EXECUTION_APPROVAL_PACKET_PASS",
  "sshExecutionAllowed": false,
  "deploymentAllowed": false,
  "installAllowed": false,
  "dbMutationAllowed": false,
  "authMutationAllowed": false,
  "secretsMutationAllowed": false,
  "runtimeActionAllowed": false,
  "approvalRequiredBeforeAnySsh": true,
  "humanApprovalRequired": true,
  "commandWhitelist": [
    "hostname",
    "whoami",
    "date",
    "uptime",
    "uname -a",
    "df -h",
    "free -h",
    "ps aux",
    "systemctl status <approved-service>",
    "journalctl -u <approved-service> --no-pager -n 100",
    "ls -al <approved-path>",
    "cat <approved-non-secret-file>",
    "find <approved-path> -maxdepth 2 -type f"
  ],
  "commandBlacklist": [
    "sudo",
    "su",
    "chmod",
    "chown",
    "rm",
    "mv",
    "cp",
    "mkdir",
    "touch",
    "vi",
    "vim",
    "nano",
    "systemctl restart",
    "systemctl stop",
    "systemctl start",
    "systemctl enable",
    "systemctl disable",
    "service restart",
    "kill",
    "pkill",
    "docker",
    "docker compose",
    "kubectl",
    "npm install",
    "pip install",
    "apt",
    "yum",
    "dnf",
    "systemctl edit",
    "crontab",
    "psql write operations",
    "mysql write operations",
    "any command containing password/token/secret/private key output"
  ],
  "stopConditions": [
    "server identity mismatch",
    "elevated privilege requested",
    "command not on whitelist",
    "sensitive output appears",
    "customer or security approval withdrawn",
    "runtime mutation required",
    "DB mutation required",
    "evidence capture failure"
  ],
  "evidenceChecklist": [
    "approval record",
    "command whitelist version",
    "forbidden command blacklist version",
    "future approved observation transcript",
    "timestamped command output",
    "stop-condition log",
    "final observation decision"
  ],
  "redactionPolicy": [
    "redact passwords",
    "redact tokens",
    "redact private keys",
    "redact certificates",
    "redact credential strings",
    "redact secret-like values",
    "stop capture and escalate if sensitive material appears"
  ],
  "relationToPriorPrechecks": {
    "r1": "dual-server read-only environment audit baseline",
    "r2": "approved read-only access window plan",
    "r3": "actual approved read-only observation plan",
    "r4": "read-only SSH execution approval packet only"
  }
}
