{
  "registryName": "VANTARIS ONE Asset Context GA R1 Registry",
  "registryVersion": "1.0.0",
  "scope": "ASSET_CONTEXT_GA_R1",
  "moduleId": "asset-context",
  "capability": "Unified Asset / System / Event / Work Order / Evidence Linkage",
  "visualStyle": "VANTARIS_LIGHT_OPERATIONS_CONSOLE",
  "releaseScope": "READ_ONLY_UNIFIED_LINKAGE",
  "passMarker": "ONE_ASSET_CONTEXT_GA_R1_UNIFIED_LINKAGE_PASS",
  "apiNamespace": "/api/v1/one/asset-context",
  "uiRoute": "/one/assets/context",
  "graphMode": "local-readonly-asset-context-projection",
  "readOnly": true,
  "runtimeEnabled": false,
  "dbWriteEnabled": false,
  "assetGraphWriteEnabled": false,
  "edgeCommandExecution": false,
  "linkCommandExecution": false,
  "deviceControlEnabled": false,
  "productionActivation": false,
  "dbMigration": false,
  "authMutation": false,
  "oneAdapterIntroduced": false,
  "sshExecuted": false,
  "deploymentExecuted": false,
  "installExecuted": false,
  "linkedObjectTypes": [
    "asset",
    "system",
    "device",
    "event",
    "workOrder",
    "maintenanceTask",
    "uhmiPanel",
    "ucdeEvidence",
    "report",
    "customerDelivery",
    "foundationDiagnostics"
  ],
  "apiRoutes": [
    "GET /api/v1/one/asset-context/health",
    "GET /api/v1/one/asset-context/summary",
    "GET /api/v1/one/asset-context/assets",
    "GET /api/v1/one/asset-context/assets/<asset_id>",
    "GET /api/v1/one/asset-context/assets/<asset_id>/links",
    "GET /api/v1/one/asset-context/graph",
    "GET /api/v1/one/asset-context/guardrails"
  ],
  "providerInputs": [
    "src.assets.assets_service.AssetsTopologyService",
    "src.umms.umms_service.UmmsMaintenanceService",
    "src.ucde.evidence_service.UcdeEvidenceService",
    "src.uhmi.uhmi_provider read-only functions",
    "src.reports.reports_service.ReportsService",
    "src.customer_delivery.readonly_preview_provider.customer_delivery_preview",
    "src.foundation_diagnostics.service.FoundationDiagnosticsService"
  ],
  "guardrails": [
    "Read-only aggregation only",
    "No DB write",
    "No Asset Graph canonical write",
    "No DB migration",
    "No auth/login/JWT/RBAC mutation",
    "No runtime activation",
    "No device control",
    "No EDGE command execution",
    "No LINK command execution",
    "No SSH, deployment, or install action",
    "No ONE Adapter introduction",
    "No PDF/Excel/ZIP/report artifact generation"
  ]
}

