      "auditRequirement": "ON_DENIAL",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "SITE_SCOPE",
      "purpose": "Constrain access to an allowed site or resource-derived site.",
      "authoritativeProvider": "Governance & Security",
      "input": "Claims and resource context",
      "decision": "IN_SCOPE_OR_DENY",
      "denialCode": "SITE_SCOPE_DENIED",
      "auditRequirement": "ON_DENIAL",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "PACKAGE_ENTITLEMENT",
      "purpose": "Confirm tenant entitlement independently of installation state.",
      "authoritativeProvider": "Governance & Security",
      "input": "Tenant and package",
      "decision": "ENTITLED_OR_DENY",
      "denialCode": "ENTITLEMENT_REQUIRED",
      "auditRequirement": "ON_DENIAL",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "PACKAGE_INSTALLED",
      "purpose": "Confirm package artifacts are installed.",
      "authoritativeProvider": "Governance & Security",
      "input": "Package state",
      "decision": "INSTALLED_OR_DENY",
      "denialCode": "PACKAGE_NOT_INSTALLED",
      "auditRequirement": "ON_DENIAL",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "PACKAGE_ENABLED",
      "purpose": "Confirm package is enabled for the tenant.",
      "authoritativeProvider": "Governance & Security",
      "input": "Package state",
      "decision": "ENABLED_OR_DENY",
      "denialCode": "PACKAGE_DISABLED",
      "auditRequirement": "ON_DENIAL",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "PERMISSION",
      "purpose": "Authorize the declared business action.",
      "authoritativeProvider": "Governance & Security",
      "input": "Identity permissions and route requirement",
      "decision": "ALLOW_OR_DENY",
      "denialCode": "PERMISSION_DENIED",
      "auditRequirement": "ON_DENIAL_AND_SENSITIVE_ALLOW",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "RESOURCE_OWNERSHIP_OBJECT_SCOPE",
      "purpose": "Validate object-level tenant, site, ownership and relationship scope.",
      "authoritativeProvider": "Owning business module",
      "input": "Canonical resource identifier",
      "decision": "IN_SCOPE_OR_DENY",
      "denialCode": "RESOURCE_SCOPE_DENIED",
      "auditRequirement": "ON_DENIAL",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "STATE_TRANSITION_RULE",
      "purpose": "Validate the requested domain state transition.",
      "authoritativeProvider": "Owning business module",
      "input": "Current state and requested transition",
      "decision": "VALID_OR_DENY",
      "denialCode": "ACTION_NOT_ALLOWED",
      "auditRequirement": "MUTATIONS",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "ACTION_APPROVAL",
      "purpose": "Require an approved decision where policy demands separation of duties.",
      "authoritativeProvider": "Owning business workflow or ONE Orchestrator",
      "input": "Action and approval context",
      "decision": "APPROVED_OR_DENY",
      "denialCode": "APPROVAL_REQUIRED",
      "auditRequirement": "ALWAYS_WHEN_APPLICABLE",
      "failurePolicy": "FAIL_CLOSED"
    },
    {
      "stageId": "AUDIT_RECORD",
      "purpose": "Persist the authoritative security and business action record.",
