  "sensitiveDataPolicy": {
    "classificationClasses": [
      "PROHIBITED",
      "REDACTED",
      "HASHED",
      "TOKENIZED_REFERENCE",
      "CLASSIFIED_METADATA",
      "ALLOWED_NON_SENSITIVE"
    ],
    "prohibitedContent": [
      "PASSWORDS",
      "PRIVATE_KEYS",
      "SEED_PHRASES",
      "BEARER_TOKENS",
      "REFRESH_TOKENS",
      "COMPLETE_AUTHENTICATION_HEADERS",
      "DATABASE_CREDENTIALS",
      "RAW_LICENSE_TOKENS",
      "CONFIDENTIAL_FILE_CONTENTS",
      "UNRESTRICTED_TELEMETRY_PAYLOADS",
      "COMPLETE_PERSONAL_DATA_RECORDS"
    ],
    "fieldResponsibilities": {
      "routeHandler": "Supply identifiers and classified metadata, never raw secrets or full bodies.",
      "auditEmitter": "Enforce allowlist, redaction, hashing and tokenized references before delivery.",
      "auditStore": "Reject prohibited classes and preserve classification metadata.",
      "consumer": "Apply least privilege and retention controls."
    },
    "defaultPolicy": "PROHIBITED_UNLESS_EXPLICITLY_CLASSIFIED"
  },
  "evidenceRelationshipPolicy": {
    "auditRecordIsEvidenceRecord": false,
    "relationshipMechanism": "EvidenceReference",
    "relationshipOwner": "Evidence Center",
    "auditOwner": "Governance & Security",
    "integrityPolicy": "Reference immutable auditId and optional digest; do not duplicate sensitive audit payload."
  },
  "retentionClasses": [
