// UFMS B1–B6 domain + B7 Auth/RBAC (User, Role, Permission).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// UFMS Commercial V1.0 fixed status enums
enum AlarmStatus {
  NEW
  ACKNOWLEDGED
  CORRELATED
  CONVERTED
  SUPPRESSED
  CLOSED
}

enum EpisodeStatus {
  OPEN
  CORRELATING
  LINKED_TO_PROBLEM
  CLOSED
}

enum ProblemStatus {
  OPEN
  UNDER_INVESTIGATION
  WORK_ORDER_CREATED
  MONITORING
  RESOLVED
  CLOSED
  REOPENED
}

enum WorkOrderStatus {
  NEW
  ACKNOWLEDGED
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  PENDING_PARTS
  PENDING_REQUESTER_CONFIRMATION
  PENDING_SUPERVISOR_REVIEW
  CLOSED
  REOPENED
  CANCELLED
}

enum InspectionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  MISSED
  EXCEPTION_FOUND
  CONVERTED_TO_WORK_ORDER
}

enum SlaStatus {
  NOT_STARTED
  RUNNING
  PAUSED
  WARNING
  BREACHED
  MET
  WAIVED
}

enum RfqCoverageStatus {
  FULL
  PARTIAL
  CONFIGURABLE
  INTEGRATION_REQUIRED
  CUSTOM_REQUIRED
  PLANNED_IN_V2
  EXCLUDED
}

enum ConnectorStatus {
  ONLINE
  DEGRADED
  OFFLINE
  ERROR
  UNKNOWN
}

model Site {
  siteId    String   @id @map("site_id")
  siteCode  String   @map("site_code")
  siteName  String   @map("site_name")
  country   String
  city      String
  siteType  String   @map("site_type")
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assets          Asset[]
  devices         Device[]
  externalSystems ExternalSystem[]
  connectors      Connector[]
  locations       Location[]
  episodes        Episode[]
  problems        Problem[]
  slaPolicies     SlaPolicy[]
  sopRules        SopRule[]
  inspectionPlans InspectionPlan[]
  requesters      Requester[]
  contractors     Contractor[]
  spareParts      SparePart[]

  @@unique([siteCode])
  @@index([siteType])
  @@index([status])
  @@map("tbl_site")
}

model Location {
  locationId       String   @id @map("location_id")
  siteId           String   @map("site_id")
  parentLocationId String?  @map("parent_location_id")
  locationCode     String   @map("location_code")
  locationName     String   @map("location_name")
  locationType     String   @map("location_type")
  status           String
  description      String?
  metadata         Json?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  site              Site               @relation(fields: [siteId], references: [siteId], onDelete: Restrict)
  parentLocation    Location?          @relation("LocationHierarchy", fields: [parentLocationId], references: [locationId], onDelete: Restrict)
  childLocations    Location[]         @relation("LocationHierarchy")
  assets            Asset[]
  alarms            Alarm[]
  events            Event[]
  episodes          Episode[]
  workOrders        WorkOrder[]
  problems          Problem[]
  inspectionPlans   InspectionPlan[]
  inspectionRecords InspectionRecord[]

  @@unique([siteId, locationCode])
  @@index([siteId, status])
  @@index([parentLocationId])
  @@index([locationType])
  @@map("tbl_location")
}

model Asset {
  assetId       String   @id @map("asset_id")
  siteId        String   @map("site_id")
  locationId    String?  @map("location_id")
  parentAssetId String?  @map("parent_asset_id")
  assetCode     String   @map("asset_code")
  assetName     String   @map("asset_name")
  assetType     String   @map("asset_type")
  status        String
  criticality   String?
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  site              Site               @relation(fields: [siteId], references: [siteId], onDelete: Restrict)
  location          Location?          @relation(fields: [locationId], references: [locationId], onDelete: SetNull)
  parentAsset       Asset?             @relation("AssetHierarchy", fields: [parentAssetId], references: [assetId], onDelete: Restrict)
  childAssets       Asset[]            @relation("AssetHierarchy")
  devices           Device[]
  points            Point[]
  workOrders        WorkOrder[]
  alarms            Alarm[]
  problems          Problem[]
  inspectionPlans   InspectionPlan[]
  inspectionRecords InspectionRecord[]
  spareParts        SparePart[]

  @@unique([siteId, assetCode])
  @@index([siteId, status])
  @@index([parentAssetId])
  @@index([assetType])
  @@index([status])
  @@map("tbl_asset")
}

model Device {
  deviceId   String   @id @map("device_id")
  siteId     String   @map("site_id")
  assetId    String   @map("asset_id")
  deviceCode String   @map("device_code")
  deviceName String   @map("device_name")
  deviceType String   @map("device_type")
  status     String
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  site   Site    @relation(fields: [siteId], references: [siteId], onDelete: Restrict)
  asset  Asset   @relation(fields: [assetId], references: [assetId], onDelete: Restrict)
  points Point[]

  @@index([siteId, status])
  @@index([assetId])
  @@index([deviceType])
  @@index([status])
  @@map("tbl_device")
}

model Point {
  pointId   String   @id @map("point_id")
  deviceId  String   @map("device_id")
  assetId   String   @map("asset_id")
  pointCode String   @map("point_code")
  pointName String   @map("point_name")
  pointType String   @map("point_type")
  unit      String
  value     Json
  quality   String
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  device Device @relation(fields: [deviceId], references: [deviceId], onDelete: Restrict)
  asset  Asset  @relation(fields: [assetId], references: [assetId], onDelete: Restrict)

  @@index([deviceId])
  @@index([assetId, quality])
  @@index([pointType])
  @@index([quality])
  @@map("tbl_point")
}

model ExternalSystem {
  externalSystemId    String    @id @map("external_system_id")
  siteId              String    @map("site_id")
  systemCode          String    @map("system_code")
  systemName          String    @map("system_name")
  systemType          String    @map("system_type")
  vendor              String
  status              String
  description         String
  externalReferenceId String?   @map("external_reference_id")
  sourceRecordId      String?   @map("source_record_id")
  trustLevel          String?   @map("trust_level")
  chainStatus         String?   @map("chain_status")
  verificationStatus  String?   @map("verification_status")
  complianceTag       String?   @map("compliance_tag")
  isActive            Boolean   @default(true) @map("is_active")
  deletedAt           DateTime? @map("deleted_at")
  deletedById         String?   @map("deleted_by_id")
  createdById         String?   @map("created_by_id")
  updatedById         String?   @map("updated_by_id")
  productName         String?   @map("product_name")
  productVersion      String?   @map("product_version")
  networkZone         String?   @map("network_zone")
  metadata            Json?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  site                Site                 @relation(fields: [siteId], references: [siteId], onDelete: Restrict)
  connectors          Connector[]
  faultSources        FaultSource[]
  integrationProfiles IntegrationProfile[]
  rawMessages         RawMessage[]
  events              Event[]

  @@unique([siteId, systemCode])
  @@index([siteId, status])
  @@index([systemType])
  @@index([status])
  @@index([isActive])
  @@map("tbl_external_system")
}

model Adapter {
  adapterId   String   @id @map("adapter_id")
  adapterCode String   @map("adapter_code")
  adapterName String   @map("adapter_name")
  protocol    String
  version     String
  status      String
  description String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  connectors Connector[]

  @@unique([adapterCode])
  @@index([protocol, status])
  @@index([status])
  @@map("tbl_adapter")
}

model Connector {
  connectorId      String          @id @map("connector_id")
  siteId           String          @map("site_id")
  adapterId        String          @map("adapter_id")
  externalSystemId String          @map("external_system_id")
  connectorCode    String          @map("connector_code")
  connectorName    String          @map("connector_name")
  protocol         String
  status           ConnectorStatus @default(UNKNOWN)
  lastPollTime     DateTime        @map("last_poll_time")
  lastErrorMessage String?         @map("last_error_message")
  description      String
  metadata         Json?
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  site           Site           @relation(fields: [siteId], references: [siteId], onDelete: Restrict)
  adapter        Adapter        @relation(fields: [adapterId], references: [adapterId], onDelete: Restrict)
  externalSystem ExternalSystem @relation(fields: [externalSystemId], references: [externalSystemId], onDelete: Restrict)
  faultSources   FaultSource[]
  events         Event[]
  alarms         Alarm[]

  @@index([siteId, status])
  @@index([adapterId])
  @@index([externalSystemId])
  @@index([protocol])
  @@index([status])
  @@map("tbl_connector")
}

model FaultSource {
  sourceId             String    @id @map("source_id")
  connectorId          String    @map("connector_id")
  externalSystemId     String    @map("external_system_id")
  sourceName           String    @map("source_name")
  sourceType           String    @map("source_type")
  protocol             String
  status               String
  lastPollTime         DateTime  @map("last_poll_time")
  sourceCategory       String?   @map("source_category")
  systemDomain         String?   @map("system_domain")
  siteName             String?   @map("site_name")
  location             String?
  ownerTeam            String?   @map("owner_team")
  governanceStatus     String?   @map("governance_status")
  trustLevel           String?   @map("trust_level")
  dataCriticality      String?   @map("data_criticality")
  validationRequired   Boolean   @default(false) @map("validation_required")
  importAllowed        Boolean   @default(true) @map("import_allowed")
  eventCreationAllowed Boolean   @default(true) @map("event_creation_allowed")
  notes                String?
  lastSeenAt           DateTime? @map("last_seen_at")
  code                 String?   @unique
  integrationProfileId String?   @map("integration_profile_id")
  externalReferenceId  String?   @map("external_reference_id")
  sourceRecordId       String?   @map("source_record_id")
  chainStatus          String?   @map("chain_status")
  verificationStatus   String?   @map("verification_status")
  complianceTag        String?   @map("compliance_tag")
  isActive             Boolean   @default(true) @map("is_active")
  deletedAt            DateTime? @map("deleted_at")
  deletedById          String?   @map("deleted_by_id")
  createdById          String?   @map("created_by_id")
  updatedById          String?   @map("updated_by_id")
  metadata             Json?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  connector      Connector      @relation(fields: [connectorId], references: [connectorId], onDelete: Restrict)
  externalSystem ExternalSystem @relation(fields: [externalSystemId], references: [externalSystemId], onDelete: Restrict)
  events         Event[]

  @@index([connectorId])
  @@index([externalSystemId, status])
  @@index([sourceType])
  @@index([status])
  @@map("tbl_fault_source")
}

model ImportBatch {
  importBatchId         String   @id @map("import_batch_id")
  batchName             String   @map("batch_name")
  fileName              String   @map("file_name")
  fileSize              Int?     @map("file_size")
  fileHash              String?  @map("file_hash")
  sourceType            String   @default("csv") @map("source_type")
  importMode            String   @default("events_csv") @map("import_mode")
  dryRun                Boolean  @default(false) @map("dry_run")
  status                String
  totalRows             Int      @map("total_rows")
  validRows             Int      @map("valid_rows")
  createdRows           Int      @map("created_rows")
  skippedRows           Int      @map("skipped_rows")
  failedRows            Int      @map("failed_rows")
  createdEventCount     Int      @default(0) @map("created_event_count")
  createdIncidentCount  Int      @default(0) @map("created_incident_count")
  createdWorkOrderCount Int      @default(0) @map("created_work_order_count")
  importedBy            String   @map("imported_by")
  importedAt            DateTime @default(now()) @map("imported_at")
  createdEventIds       Json?    @map("created_event_ids")
  validationSummary     Json?    @map("validation_summary")
  errorSummary          Json?    @map("error_summary")
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  events Event[]
  items  ImportBatchItem[]

  @@index([status])
  @@index([importedBy])
  @@index([importedAt])
  @@index([fileName])
  @@map("tbl_import_batch")
}

model ImportBatchItem {
  importBatchItemId String   @id @map("import_batch_item_id")
  importBatchId     String   @map("import_batch_id")
  rowNumber         Int      @map("row_number")
  sourceRecordKey   String?  @map("source_record_key")
  targetType        String?  @map("target_type")
  targetId          String?  @map("target_id")
  processingStatus  String   @map("processing_status")
  validationMessage String?  @map("validation_message")
  errorMessage      String?  @map("error_message")
  createdAt         DateTime @default(now()) @map("created_at")

  importBatch ImportBatch @relation(fields: [importBatchId], references: [importBatchId], onDelete: Cascade)

  @@index([importBatchId])
  @@index([importBatchId, rowNumber])
  @@map("tbl_import_batch_item")
}

model Event {
  eventId              String    @id @map("event_id")
  sourceId             String    @map("source_id")
  sourceLabel          String    @map("source_label")
  severity             String
  category             String
  assetLabel           String    @map("asset_label")
  title                String
  status               String
  occurredTime         DateTime  @map("occurred_time")
  incidentId           String?   @map("incident_id")
  importBatchId        String?   @map("import_batch_id")
  eventCode            String?   @unique @map("event_code")
  description          String?
  siteId               String?   @map("site_id")
  locationId           String?   @map("location_id")
  assetId              String?   @map("asset_id")
  deviceId             String?   @map("device_id")
  connectorId          String?   @map("connector_id")
  acknowledgedAt       DateTime? @map("acknowledged_at")
  resolvedAt           DateTime? @map("resolved_at")
  closedAt             DateTime? @map("closed_at")
  createdById          String?   @map("created_by_id")
  updatedById          String?   @map("updated_by_id")
  metadata             Json?
  chainStatus          String?   @map("chain_status")
  verificationStatus   String?   @map("verification_status")
  complianceTag        String?   @map("compliance_tag")
  isActive             Boolean   @default(true) @map("is_active")
  deletedAt            DateTime? @map("deleted_at")
  deletedById          String?   @map("deleted_by_id")
  externalSystemId     String?   @map("external_system_id")
  integrationProfileId String?   @map("integration_profile_id")
  rawMessageId         String?   @map("raw_message_id")
  sourceRecordId       String?   @map("source_record_id")
  externalReferenceId  String?   @map("external_reference_id")
  externalEventId      String?   @map("external_event_id")
  sourceType           String?   @map("source_type")
  sourceCategory       String?   @map("source_category")
  eventCategory        String?   @map("event_category")
  confidence           Float?    @map("confidence")
  mediaUrl             String?   @map("media_url")
  snapshotUrl          String?   @map("snapshot_url")
  videoClipUrl         String?   @map("video_clip_url")
  networkZone          String?   @map("network_zone")
  trustLevel           String?   @map("trust_level")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  faultSource        FaultSource         @relation(fields: [sourceId], references: [sourceId], onDelete: Restrict)
  incident           Incident?           @relation(fields: [incidentId], references: [incidentId], onDelete: Restrict)
  importBatch        ImportBatch?        @relation(fields: [importBatchId], references: [importBatchId], onDelete: SetNull)
  externalSystem     ExternalSystem?     @relation(fields: [externalSystemId], references: [externalSystemId], onDelete: SetNull)
  integrationProfile IntegrationProfile? @relation(fields: [integrationProfileId], references: [profileId], onDelete: SetNull)
  rawMessage         RawMessage?         @relation(fields: [rawMessageId], references: [id], onDelete: SetNull)
  connector          Connector?          @relation(fields: [connectorId], references: [connectorId], onDelete: SetNull)
  location           Location?           @relation(fields: [locationId], references: [locationId], onDelete: SetNull)
  alarms             Alarm[]

  @@index([sourceId, occurredTime])
  @@index([connectorId])
  @@index([locationId])
  @@index([externalSystemId])
  @@index([integrationProfileId])
  @@index([rawMessageId])
  @@index([sourceRecordId])
  @@index([externalEventId])
  @@index([isActive])
  @@index([incidentId])
  @@index([importBatchId])
  @@index([severity])
  @@index([status])
  @@index([category])
  @@index([occurredTime])
  @@index([siteId])
  @@index([assetId])
  @@index([deviceId])
  @@map("tbl_event")
}

model Incident {
  incidentId  String    @id @map("incident_id")
  title       String
  priority    String
  status      String
  severity    String
  category    String
  assignedTo  String    @map("assigned_to")
  assetLabel  String    @map("asset_label")
  incidentNo  String?   @unique @map("incident_no")
  description String?
  eventId     String?   @map("event_id")
  rootCause   String?   @map("root_cause")
  resolution  String?
  resolvedAt  DateTime? @map("resolved_at")
  closedAt    DateTime? @map("closed_at")
  createdById String?   @map("created_by_id")
  updatedById String?   @map("updated_by_id")
  metadata    Json?
  createdAt   DateTime  @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  events     Event[]
  workOrders WorkOrder[]
  decisions  Decision[]

  @@index([priority])
  @@index([status])
  @@index([severity])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("tbl_incident")
}

model WorkOrder {
  workOrderId          String          @id @map("work_order_id")
  incidentId           String?         @map("incident_id")
  problemId            String?         @map("problem_id")
  episodeId            String?         @map("episode_id")
  assetId              String?         @map("asset_id")
  locationId           String?         @map("location_id")
  slaPolicyId          String?         @map("sla_policy_id")
  requesterId          String?         @map("requester_id")
  contractorId         String?         @map("contractor_id")
  title                String
  assetLabel           String          @map("asset_label")
  assignedTo           String          @map("assigned_to")
  priority             String
  status               WorkOrderStatus @default(NEW)
  slaStatus            SlaStatus       @default(NOT_STARTED) @map("sla_status")
  dueDate              DateTime        @map("due_date")
  slaDueAt             DateTime?       @map("sla_due_at")
  slaBreachedAt        DateTime?       @map("sla_breached_at")
  workOrderNo          String?         @unique @map("work_order_no")
  description          String?
  eventId              String?         @map("event_id")
  deviceId             String?         @map("device_id")
  completedAt          DateTime?       @map("completed_at")
  closedAt             DateTime?       @map("closed_at")
  requesterConfirmedAt DateTime?       @map("requester_confirmed_at")
  requesterConfirmedBy String?         @map("requester_confirmed_by")
  supervisorClosedAt   DateTime?       @map("supervisor_closed_at")
  supervisorClosedBy   String?         @map("supervisor_closed_by")
  resolution           String?
  createdById          String?         @map("created_by_id")
  updatedById          String?         @map("updated_by_id")
  metadata             Json?
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  incident          Incident?            @relation(fields: [incidentId], references: [incidentId], onDelete: Restrict)
  problem           Problem?             @relation(fields: [problemId], references: [problemId], onDelete: SetNull)
  episode           Episode?             @relation(fields: [episodeId], references: [episodeId], onDelete: SetNull)
  asset             Asset?               @relation(fields: [assetId], references: [assetId], onDelete: Restrict)
  location          Location?            @relation(fields: [locationId], references: [locationId], onDelete: SetNull)
  slaPolicy         SlaPolicy?           @relation(fields: [slaPolicyId], references: [slaPolicyId], onDelete: SetNull)
  requester         Requester?           @relation(fields: [requesterId], references: [requesterId], onDelete: SetNull)
  contractor        Contractor?          @relation(fields: [contractorId], references: [contractorId], onDelete: SetNull)
  decisions         Decision[]
  evidenceItems     Evidence[]
  sparePartUsages   WorkOrderSparePart[]
  inspectionRecords InspectionRecord[]

  @@index([incidentId])
  @@index([problemId])
  @@index([episodeId])
  @@index([assetId])
  @@index([locationId])
  @@index([slaPolicyId])
  @@index([requesterId])
  @@index([contractorId])
  @@index([priority])
  @@index([status])
  @@index([slaStatus])
  @@index([assignedTo])
  @@index([dueDate])
  @@map("tbl_work_order")
}

model Timeline {
  timelineId     String   @id @map("timeline_id")
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  action         String
  message        String
  actor          String
  timestamp      DateTime
  source         String   @default("local")
  syncStatus     String   @default("synced") @map("sync_status")
  actionType     String?  @map("action_type")
  title          String?
  description    String?
  actorId        String?  @map("actor_id")
  beforeSnapshot Json?    @map("before_snapshot")
  afterSnapshot  Json?    @map("after_snapshot")
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId, timestamp])
  @@index([actor, timestamp])
  @@index([timestamp])
  @@map("tbl_timeline")
}

model AuditLog {
  auditId    String   @id @map("audit_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  module     String?
  action     String
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  actor      String
  actorRole  String?  @map("actor_role")
  ipAddress  String?  @map("ip_address")
  result     String?  @default("success")
  evidenceId String?  @map("evidence_id")
  timestamp  DateTime
  hash       String   @map("audit_hash")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([entityType, entityId, timestamp])
  @@index([action])
  @@index([actor, timestamp])
  @@index([actorRole])
  @@index([timestamp])
  @@index([hash])
  @@index([evidenceId])
  @@map("tbl_audit_log")
}

model Evidence {
  evidenceId          String   @id @map("evidence_id")
  workOrderId         String?  @map("work_order_id")
  entityType          String   @map("entity_type")
  entityId            String   @map("entity_id")
  fileName            String   @map("file_name")
  fileHash            String   @map("file_hash")
  storagePath         String   @map("storage_path")
  uploadedBy          String   @map("uploaded_by")
  uploadedAt          DateTime @map("uploaded_at")
  evidenceNo          String?  @unique @map("evidence_no")
  evidenceType        String?  @map("evidence_type")
  title               String?
  description         String?
  fileUrl             String?  @map("file_url")
  textContent         String?  @map("text_content")
  evidenceHash        String?  @map("evidence_hash")
  verificationStatus  String?  @map("verification_status")
  createdById         String?  @map("created_by_id")
  mediaUrl            String?  @map("media_url")
  snapshotUrl         String?  @map("snapshot_url")
  videoClipUrl        String?  @map("video_clip_url")
  thumbnailUrl        String?  @map("thumbnail_url")
  sourceSystemId      String?  @map("source_system_id")
  externalReferenceId String?  @map("external_reference_id")
  chainStatus         String?  @map("chain_status")
  metadata            Json?
