# AN_VANTARIS_LINK offline deployment example environment
# STRUCTURE_ONLY — do not store secrets here.

LINK_NODE_ID=link-node-local
LINK_MODE=offline-dry-run
LINK_PRODUCTION_DELIVERY_ALLOWED=false
LINK_ENDPOINT_APPROVED=false
LINK_DIRECT_UFMS_DB_ACCESS_ALLOWED=false
LINK_WRITEBACK_ALLOWED=false
LINK_CONSUMER_IMPLEMENTATION_INCLUDED=false

# References only. Do not place real credentials in this file.
LINK_MACHINE_IDENTITY_REF=secret://link/machine-identity/ref-only
LINK_UFMS_ENDPOINT_REF=endpoint://ufms/app-api/ref-only
LINK_CONTRACTS_MANIFEST_REF=AN_VANTARIS_Contracts/manifest/AN_VANTARIS_CONTRACTS_SCHEMA_MANIFEST.v1.json
