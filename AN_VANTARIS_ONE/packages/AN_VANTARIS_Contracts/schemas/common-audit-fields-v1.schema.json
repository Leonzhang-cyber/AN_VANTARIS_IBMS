{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantaris.local/contracts/schemas/common-audit-fields-v1.schema.json",
  "title": "CommonAuditFieldsV1",
  "type": "object",
  "additionalProperties": true,
  "$defs": {
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601."
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601."
    },
    "observedTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601."
    },
    "sourceTimestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601."
    },
    "createdBy": {
      "type": "string",
      "minLength": 1
    },
    "updatedBy": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    }
  }
}
