{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantaris.local/contracts/schemas/health-v1.schema.json",
  "title": "HealthV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
