{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantaris.local/contracts/schemas/link-dlq-item-v1.schema.json",
  "title": "LinkDlqItemV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "dlqItemId",
    "envelopeId",
    "deliveryId",
    "finalAttemptNo",
    "failureCode",
    "failureMessage",
    "failureCategory",
    "retryable",
    "originalEnvelopeRef",
    "originalWireEventRef",
    "payloadSnapshot",
    "traceContext",
    "idempotencyKey",
    "movedToDlqAt",
    "retentionUntil",
    "status"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "dlqItemId": {
      "type": "string",
      "minLength": 1
    },
    "envelopeId": {
      "type": "string",
      "minLength": 1
    },
    "deliveryId": {
      "type": "string",
      "minLength": 1
    },
    "finalAttemptNo": {
      "type": "integer",
      "minimum": 1
    },
    "failureCode": {
      "type": "string",
      "minLength": 1
    },
    "failureMessage": {
      "type": "string",
      "minLength": 1
    },
    "failureCategory": {
      "type": "string",
      "enum": [
        "transport",
        "validation",
        "downstream",
        "timeout",
        "unknown"
      ]
    },
    "retryable": {
      "type": "boolean"
    },
    "originalEnvelopeRef": {
      "type": "string",
      "format": "uri"
    },
    "originalWireEventRef": {
      "type": "string",
      "format": "uri"
    },
    "payloadSnapshot": {
      "type": "object",
      "additionalProperties": true
    },
    "traceContext": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/traceContext"
    },
    "idempotencyKey": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/idempotencyKey"
    },
    "movedToDlqAt": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp."
    },
    "retentionUntil": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO-8601 timestamp."
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "replayed",
        "expired",
        "closed"
      ]
    }
  }
}
