{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "link-delivery-idempotency-receipt.v1",
  "title": "LINK Delivery Idempotency Receipt Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deliveryId",
    "deliveryType",
    "handoff",
    "target",
    "idempotency",
    "attempt",
    "receipt",
    "boundary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "link-delivery-idempotency-receipt.v1"
    },
    "deliveryId": {
      "type": "string",
      "minLength": 1
    },
    "deliveryType": {
      "type": "string",
      "enum": [
        "UFMS_APP_API",
        "VANTARIS_ONE_BOUNDARY",
        "UMMS_WORK_ORDER_BOUNDARY",
        "UCDE_EVIDENCE_BOUNDARY",
        "LOCAL_DRY_RUN",
        "UNKNOWN"
      ]
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "envelopeId",
        "recordType",
        "eventId",
        "traceId",
        "gatewayId",
        "streamId",
        "sequenceNumber",
        "payloadHash"
      ],
      "properties": {
        "envelopeId": {
          "type": "string",
          "minLength": 1
        },
        "recordType": {
          "type": "string",
          "minLength": 1
        },
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "traceId": {
          "type": "string",
          "minLength": 1
        },
        "correlationId": {
          "type": "string"
        },
        "gatewayId": {
          "type": "string",
          "minLength": 1
        },
        "edgeId": {
          "type": "string"
        },
        "streamId": {
          "type": "string",
          "minLength": 1
        },
        "sequenceNumber": {
          "type": "integer",
          "minimum": 0
        },
        "payloadHash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "targetId",
        "targetKind",
        "approvalStatus",
        "endpointRef",
        "method"
      ],
      "properties": {
        "targetId": {
          "type": "string",
          "minLength": 1
        },
        "targetKind": {
          "type": "string",
          "enum": [
            "UFMS_APP_API",
            "ONE_PROJECTION_BOUNDARY",
            "UMMS_WORK_ORDER_BOUNDARY",
            "UCDE_EVIDENCE_BOUNDARY",
            "LOCAL_DRY_RUN",
            "UNKNOWN"
          ]
        },
        "approvalStatus": {
          "type": "string",
          "enum": [
            "APPROVED",
            "NOT_APPROVED",
            "BLOCKED",
            "REVOKED",
            "UNKNOWN"
          ]
        },
        "endpointRef": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "enum": [
            "POST",
            "PUT",
            "PATCH",
            "LOCAL_APPEND",
            "NONE"
          ]
        },
        "routeTemplate": {
          "type": "string"
        },
        "requiresMachineIdentity": {
          "type": "boolean"
        },
        "credentialRef": {
          "type": "string"
        }
      }
    },
    "idempotency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "idempotencyKey",
        "dedupeScope",
        "duplicatePolicy",
        "payloadHash"
      ],
      "properties": {
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "dedupeScope": {
          "type": "string",
          "enum": [
            "TARGET",
            "STREAM",
            "GATEWAY",
            "GLOBAL",
            "UNKNOWN"
          ]
        },
        "duplicatePolicy": {
          "type": "string",
          "enum": [
            "DROP_DUPLICATE",
            "ACK_DUPLICATE",
            "DLQ_DUPLICATE",
            "RETRY_DUPLICATE",
            "UNKNOWN"
          ]
        },
        "payloadHash": {
          "type": "string",
          "minLength": 1
        },
        "previousDeliveryId": {
          "type": "string"
        },
        "duplicateDetected": {
          "type": "boolean"
        }
      }
    },
    "attempt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attemptId",
        "attemptNumber",
        "status",
        "startedAt"
      ],
      "properties": {
        "attemptId": {
          "type": "string",
          "minLength": 1
        },
        "attemptNumber": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PENDING",
            "BLOCKED",
            "SENT",
            "ACKED",
            "FAILED",
            "RETRY_SCHEDULED",
            "DLQ",
            "DUPLICATE",
            "UNKNOWN"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        },
        "httpStatus": {
          "type": ["integer", "null"],
          "minimum": 100,
          "maximum": 599
        },
        "errorCode": {
          "type": "string"
        },
        "errorMessage": {
          "type": "string"
        }
      }
    },
    "receipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "receiptId",
        "receiptStatus",
        "receivedAt",
        "acceptedByTarget"
      ],
      "properties": {
        "receiptId": {
          "type": "string",
          "minLength": 1
        },
        "receiptStatus": {
          "type": "string",
          "enum": [
            "NONE",
            "RECEIVED",
            "ACCEPTED",
            "REJECTED",
            "BLOCKED",
            "DUPLICATE",
            "TIMEOUT",
            "UNKNOWN"
          ]
        },
        "receivedAt": {
          "type": "string",
          "format": "date-time"
        },
        "acceptedByTarget": {
          "type": "boolean"
        },
        "targetReferenceId": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "retryRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retryPolicyId": {
          "type": "string"
        },
        "retryDecisionId": {
          "type": "string"
        },
        "nextRetryAt": {
          "type": "string",
          "format": "date-time"
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "dlqRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dlqItemId": {
          "type": "string"
        },
        "dlqReason": {
          "type": "string"
        },
        "movedToDlqAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidenceId",
          "evidenceType"
        ],
        "properties": {
          "evidenceId": {
            "type": "string",
            "minLength": 1
          },
          "evidenceType": {
            "type": "string",
            "enum": [
              "delivery",
              "idempotency",
              "receipt",
              "attempt",
              "endpoint_approval",
              "retry",
              "dlq",
              "audit",
              "unknown"
            ]
          },
          "sourcePath": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "linkRuntimeEnabled",
        "linkProductionDeliveryAllowed",
        "endpointApproved",
        "directUfmsDbAccessAllowed",
        "writebackAllowed",
        "consumerImplementationIncluded"
      ],
      "properties": {
        "linkRuntimeEnabled": {
          "type": "boolean",
          "const": false
        },
        "linkProductionDeliveryAllowed": {
          "type": "boolean",
          "const": false
        },
        "endpointApproved": {
          "type": "boolean",
          "const": false
        },
        "directUfmsDbAccessAllowed": {
          "type": "boolean",
          "const": false
        },
        "writebackAllowed": {
          "type": "boolean",
          "const": false
        },
        "consumerImplementationIncluded": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
