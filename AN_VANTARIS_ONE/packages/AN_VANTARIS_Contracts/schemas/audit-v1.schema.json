{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantaris.local/contracts/schemas/audit-v1.schema.json",
  "title": "AuditV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "auditId",
    "actorType",
    "action",
    "targetType",
    "targetId",
    "occurredAt"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "auditId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/auditId"
    },
    "tenantId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/tenantId"
    },
    "siteId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/siteId"
    },
    "gatewayId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/gatewayId"
    },
    "connectorId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/connectorId"
    },
    "sourceSystemId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/sourceSystemId"
    },
    "status": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/status"
    },
    "createdAt": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/createdAt"
    },
    "updatedAt": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/updatedAt"
    },
    "traceContext": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/traceContext"
    },
    "correlationId": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/correlationId"
    },
    "idempotencyKey": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/idempotencyKey"
    },
    "actorType": {
      "type": "string"
    },
    "action": {
      "type": "string"
    },
    "targetType": {
      "type": "string"
    },
    "targetId": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
