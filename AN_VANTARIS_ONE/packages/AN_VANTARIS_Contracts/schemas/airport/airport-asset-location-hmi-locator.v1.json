{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "airport-asset-location-hmi-locator.v1",
  "title": "Airport Asset Location HMI Locator Metadata Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "locatorSetId",
    "site",
    "assetLocationRecords",
    "boundary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "airport-asset-location-hmi-locator.v1"
    },
    "locatorSetId": {
      "type": "string",
      "minLength": 1
    },
    "sourceSystemProfileRef": {
      "type": "string"
    },
    "connectorMatrixItemRef": {
      "type": "string"
    },
    "onboardingPacketRef": {
      "type": "string"
    },
    "tagMappingSetRef": {
      "type": "string"
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "siteId",
        "siteName"
      ],
      "properties": {
        "tenantId": {
          "type": "string"
        },
        "siteId": {
          "type": "string",
          "minLength": 1
        },
        "siteName": {
          "type": "string",
          "minLength": 1
        },
        "airportCode": {
          "type": "string"
        },
        "country": {
          "type": "string"
        },
        "timezone": {
          "type": "string"
        }
      }
    },
    "assetLocationRecords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "recordId",
          "asset",
          "location",
          "review",
          "boundary"
        ],
        "properties": {
          "recordId": {
            "type": "string",
            "minLength": 1
          },
          "asset": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "assetRef",
              "assetName",
              "assetType",
              "discipline"
            ],
            "properties": {
              "assetRef": {
                "type": "string",
                "minLength": 1
              },
              "assetName": {
                "type": "string",
                "minLength": 1
              },
              "assetType": {
                "type": "string",
                "enum": [
                  "CAMERA",
                  "ACCESS_CONTROLLER",
                  "DOOR",
                  "PA_ZONE",
                  "RADIO_DEVICE",
                  "IPTV_DEVICE",
                  "CLOCK_DEVICE",
                  "IPBX_DEVICE",
                  "TOLL_DEVICE",
                  "AHU",
                  "FCU",
                  "PUMP",
                  "FAN",
                  "CHILLER",
                  "METER",
                  "PANEL",
                  "FIRE_PANEL",
                  "LIFT",
                  "ESCALATOR",
                  "LIGHTING_CIRCUIT",
                  "SENSOR",
                  "CONTROLLER",
                  "SERVER",
                  "WORKSTATION",
                  "OTHER",
                  "UNKNOWN"
                ]
              },
              "discipline": {
                "type": "string",
                "enum": [
                  "SECURITY",
                  "ELV",
                  "MECHANICAL",
                  "ELECTRICAL",
                  "FACILITY",
                  "OPERATIONS",
                  "MAINTENANCE",
                  "ENERGY",
                  "SAFETY",
                  "OTHER"
                ]
              },
              "sourceSystemRef": {
                "type": "string"
              },
              "deviceRef": {
                "type": "string"
              },
              "pointRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "tagRefs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "criticality": {
                "type": "string",
                "enum": [
                  "CRITICAL",
                  "HIGH",
                  "MEDIUM",
                  "LOW",
                  "UNKNOWN"
                ]
              }
            }
          },
          "hierarchy": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "parentAssetRef": {
                "type": "string"
              },
              "rootAssetRef": {
                "type": "string"
              },
              "hierarchyPath": {
                "type": "string"
              },
              "systemRef": {
                "type": "string"
              },
              "subsystemRef": {
                "type": "string"
              },
              "equipmentGroupRef": {
                "type": "string"
              }
            }
          },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "locationRef"
            ],
            "properties": {
              "locationRef": {
                "type": "string",
                "minLength": 1
              },
              "terminal": {
                "type": "string"
              },
              "building": {
                "type": "string"
              },
              "level": {
                "type": "string"
              },
              "floor": {
                "type": "string"
              },
              "room": {
                "type": "string"
              },
              "zone": {
                "type": "string"
              },
              "area": {
                "type": "string"
              },
              "nearestLandmark": {
                "type": "string"
              },
              "gps": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "latitude": {
                    "type": "number",
                    "minimum": -90,
                    "maximum": 90
                  },
                  "longitude": {
                    "type": "number",
                    "minimum": -180,
                    "maximum": 180
                  }
                }
              }
            }
          },
          "hmiLocator": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hmiLocatorAvailable": {
                "type": "boolean"
              },
              "hmiSystemRef": {
                "type": "string"
              },
              "drawingRef": {
                "type": "string"
              },
              "drawingName": {
                "type": "string"
              },
              "pageRef": {
                "type": "string"
              },
              "pageName": {
                "type": "string"
              },
              "symbolRef": {
                "type": "string"
              },
              "symbolName": {
                "type": "string"
              },
              "coordinate": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "x": {
                    "type": "number"
                  },
                  "y": {
                    "type": "number"
                  },
                  "coordinateSystem": {
                    "type": "string",
                    "enum": [
                      "PIXEL",
                      "PERCENT",
                      "CAD",
                      "GIS",
                      "UNKNOWN"
                    ]
                  }
                }
              },
              "deepLinkRef": {
                "type": "string"
              },
              "screenshotRef": {
                "type": "string"
              }
            }
          },
          "engineeringMetadata": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "drawingRef": {
                "type": "string"
              },
              "panelRef": {
                "type": "string"
              },
              "circuitRef": {
                "type": "string"
              },
              "loopRef": {
                "type": "string"
              },
              "cableRef": {
                "type": "string"
              },
              "maintenanceAccessNotes": {
                "type": "string"
              },
              "safetyNotes": {
                "type": "string"
              }
            }
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "assetReviewStatus",
              "locationReviewStatus",
              "hmiReviewStatus",
              "engineeringReviewStatus"
            ],
            "properties": {
              "assetReviewStatus": {
                "type": "string",
                "enum": [
                  "NOT_REVIEWED",
                  "UNDER_REVIEW",
                  "NEEDS_CLEANUP",
                  "ACCEPTED",
                  "REJECTED",
                  "BLOCKED",
                  "UNKNOWN"
                ]
              },
              "locationReviewStatus": {
                "type": "string",
                "enum": [
                  "NOT_REVIEWED",
                  "UNDER_REVIEW",
                  "NEEDS_CLEANUP",
                  "ACCEPTED",
                  "REJECTED",
                  "BLOCKED",
                  "UNKNOWN"
                ]
              },
              "hmiReviewStatus": {
                "type": "string",
                "enum": [
                  "NOT_REVIEWED",
                  "UNDER_REVIEW",
                  "NEEDS_CLEANUP",
                  "ACCEPTED",
                  "REJECTED",
                  "BLOCKED",
                  "UNKNOWN"
                ]
              },
              "engineeringReviewStatus": {
                "type": "string",
                "enum": [
                  "NOT_REVIEWED",
                  "UNDER_REVIEW",
                  "NEEDS_CLEANUP",
                  "ACCEPTED",
                  "REJECTED",
                  "BLOCKED",
                  "UNKNOWN"
                ]
              },
              "reviewed": {
                "type": "boolean"
              },
              "reviewerRef": {
                "type": "string"
              },
              "reviewedAt": {
                "type": "string",
                "format": "date-time"
              },
              "reviewNotes": {
                "type": "string"
              }
            }
          },
          "boundary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "contractOnly",
              "runtimeAssetWriteApplied",
              "runtimeLocationWriteApplied",
              "edgeRuntimeEnabled",
              "linkProductionDeliveryAllowed",
              "directUfmsDbAccessAllowed",
              "writebackAllowed",
              "consumerImplementationIncluded"
            ],
            "properties": {
              "contractOnly": {
                "type": "boolean",
                "const": true
              },
              "runtimeAssetWriteApplied": {
                "type": "boolean",
                "const": false
              },
              "runtimeLocationWriteApplied": {
                "type": "boolean",
                "const": false
              },
              "edgeRuntimeEnabled": {
                "type": "boolean",
                "const": false
              },
              "linkProductionDeliveryAllowed": {
                "type": "boolean",
                "const": false
              },
              "directUfmsDbAccessAllowed": {
                "type": "boolean",
                "const": false
              },
              "writebackAllowed": {
                "type": "boolean",
                "const": false
              },
              "consumerImplementationIncluded": {
                "type": "boolean",
                "const": false
              }
            }
          }
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidenceId",
          "evidenceType"
        ],
        "properties": {
          "evidenceId": {
            "type": "string",
            "minLength": 1
          },
          "evidenceType": {
            "type": "string",
            "enum": [
              "asset_list",
              "location_list",
              "hmi_drawing",
              "hmi_screenshot",
              "cad_drawing",
              "zone_map",
              "engineering_review",
              "site_survey",
              "mapping_review",
              "unknown"
            ]
          },
          "sourcePath": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractOnly",
        "runtimeAssetWriteApplied",
        "runtimeLocationWriteApplied",
        "edgeRuntimeEnabled",
        "linkProductionDeliveryAllowed",
        "directUfmsDbAccessAllowed",
        "writebackAllowed",
        "consumerImplementationIncluded"
      ],
      "properties": {
        "contractOnly": {
          "type": "boolean",
          "const": true
        },
        "runtimeAssetWriteApplied": {
          "type": "boolean",
          "const": false
        },
        "runtimeLocationWriteApplied": {
          "type": "boolean",
          "const": false
        },
        "edgeRuntimeEnabled": {
          "type": "boolean",
          "const": false
        },
        "linkProductionDeliveryAllowed": {
          "type": "boolean",
          "const": false
        },
        "directUfmsDbAccessAllowed": {
          "type": "boolean",
          "const": false
        },
        "writebackAllowed": {
          "type": "boolean",
          "const": false
        },
        "consumerImplementationIncluded": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
