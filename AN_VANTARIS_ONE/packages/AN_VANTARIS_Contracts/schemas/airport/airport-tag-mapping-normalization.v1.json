{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "airport-tag-mapping-normalization.v1",
  "title": "Airport Tag Mapping Normalization Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "mappingSetId",
    "sourceSystemProfileRef",
    "connectorMatrixItemRef",
    "mappingStatus",
    "mappings",
    "boundary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "airport-tag-mapping-normalization.v1"
    },
    "mappingSetId": {
      "type": "string",
      "minLength": 1
    },
    "sourceSystemProfileRef": {
      "type": "string",
      "minLength": 1
    },
    "connectorMatrixItemRef": {
      "type": "string",
      "minLength": 1
    },
    "onboardingPacketRef": {
      "type": "string"
    },
    "mappingStatus": {
      "type": "string",
      "enum": [
        "DRAFT",
        "UNDER_REVIEW",
        "NEEDS_CLEANUP",
        "READY_FOR_DRY_RUN",
        "VALIDATED",
        "BLOCKED",
        "UNKNOWN"
      ]
    },
    "sourceContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sourceSystemId": {
          "type": "string"
        },
        "sourceSystemType": {
          "type": "string",
          "enum": [
            "CCTV",
            "ACS_SMS",
            "PA_SYSTEM",
            "RADIO_SYSTEM",
            "IPTV",
            "CLOCK_SYSTEM",
            "IPBX",
            "TOLL_SYSTEM",
            "BMS",
            "EMS",
            "MMS",
            "E_INSPECTION",
            "IFEEDBACK",
            "SECURITY_SYSTEM",
            "FIRE_ALARM",
            "LIFT_ESCALATOR",
            "LIGHTING",
            "POWER_METERING",
            "HVAC",
            "WATER",
            "OTHER"
          ]
        },
        "protocol": {
          "type": "string",
          "enum": [
            "OPC_UA",
            "OPC_DA",
            "MODBUS_TCP",
            "BACNET_IP",
            "SNMP",
            "REST_API",
            "SOAP_API",
            "SDK",
            "CSV",
            "EXCEL",
            "DATABASE_EXPORT",
            "FILE_DROP",
            "MQTT",
            "SFTP",
            "NONE",
            "UNKNOWN"
          ]
        },
        "vendor": {
          "type": "string"
        },
        "productName": {
          "type": "string"
        }
      }
    },
    "normalizationPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policyId": {
          "type": "string"
        },
        "namingConvention": {
          "type": "string",
          "enum": [
            "KEEP_RAW",
            "UPPERCASE",
            "LOWERCASE",
            "CANONICAL_DOT_PATH",
            "CANONICAL_SLASH_PATH",
            "CUSTOM_RULE",
            "UNKNOWN"
          ]
        },
        "dedupePolicy": {
          "type": "string",
          "enum": [
            "RAW_TAG",
            "NORMALIZED_TAG",
            "SOURCE_ASSET_POINT",
            "CUSTOM",
            "UNKNOWN"
          ]
        },
        "defaultQuality": {
          "type": "string",
          "enum": [
            "GOOD",
            "UNCERTAIN",
            "BAD",
            "UNKNOWN"
          ]
        },
        "timezone": {
          "type": "string"
        }
      }
    },
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mappingId",
          "raw",
          "canonical",
          "normalization",
          "review",
          "boundary"
        ],
        "properties": {
          "mappingId": {
            "type": "string",
            "minLength": 1
          },
          "raw": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "rawTagName"
            ],
            "properties": {
              "rawTagName": {
                "type": "string",
                "minLength": 1
              },
              "rawAddress": {
                "type": "string"
              },
              "rawObjectType": {
                "type": "string"
              },
              "rawUnit": {
                "type": "string"
              },
              "rawDescription": {
                "type": "string"
              },
              "rawAlarmClass": {
                "type": "string"
              },
              "rawPriority": {
                "type": "string"
              }
            }
          },
          "canonical": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "normalizedTagName",
              "objectType"
            ],
            "properties": {
              "normalizedTagName": {
                "type": "string",
                "minLength": 1
              },
              "objectType": {
                "type": "string",
                "enum": [
                  "ASSET",
                  "DEVICE",
                  "POINT",
                  "TELEMETRY",
                  "EVENT",
                  "ALARM",
                  "HEALTH",
                  "EVIDENCE",
                  "CONFIG_VERSION",
                  "THROUGHPUT",
                  "UNKNOWN"
                ]
              },
              "assetRef": {
                "type": "string"
              },
              "deviceRef": {
                "type": "string"
              },
              "pointRef": {
                "type": "string"
              },
              "sourceSystemRef": {
                "type": "string"
              },
              "signalType": {
                "type": "string",
                "enum": [
                  "ANALOG",
                  "DIGITAL",
                  "STATUS",
                  "COMMAND_STATE",
                  "ALARM",
                  "EVENT",
                  "COUNTER",
                  "TEXT",
                  "UNKNOWN"
                ]
              },
              "unit": {
                "type": "string"
              },
              "engineeringUnit": {
                "type": "string"
              },
              "discipline": {
                "type": "string",
                "enum": [
                  "SECURITY",
                  "ELV",
                  "MECHANICAL",
                  "ELECTRICAL",
                  "FACILITY",
                  "OPERATIONS",
                  "MAINTENANCE",
                  "ENERGY",
                  "SAFETY",
                  "OTHER"
                ]
              }
            }
          },
          "normalization": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ruleId",
              "ruleType",
              "valueTransform",
              "qualityMapping"
            ],
            "properties": {
              "ruleId": {
                "type": "string",
                "minLength": 1
              },
              "ruleType": {
                "type": "string",
                "enum": [
                  "DIRECT",
                  "RENAME_ONLY",
                  "UNIT_CONVERSION",
                  "BOOLEAN_MAP",
                  "ENUM_MAP",
                  "SCALE_OFFSET",
                  "ALARM_MAP",
                  "EVENT_MAP",
                  "CUSTOM",
                  "UNKNOWN"
                ]
              },
              "valueTransform": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "transformType"
                ],
                "properties": {
                  "transformType": {
                    "type": "string",
                    "enum": [
                      "NONE",
                      "MULTIPLY",
                      "ADD",
                      "SCALE_OFFSET",
                      "BOOLEAN",
                      "ENUM",
                      "STRING_NORMALIZE",
                      "CUSTOM",
                      "UNKNOWN"
                    ]
                  },
                  "scale": {
                    "type": "number"
                  },
                  "offset": {
                    "type": "number"
                  },
                  "trueValue": {
                    "type": "string"
                  },
                  "falseValue": {
                    "type": "string"
                  },
                  "enumMapRef": {
                    "type": "string"
                  }
                }
              },
              "qualityMapping": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "qualitySource"
                ],
                "properties": {
                  "qualitySource": {
                    "type": "string",
                    "enum": [
                      "PROTOCOL_NATIVE",
                      "RAW_FIELD",
                      "DEFAULT",
                      "CUSTOM",
                      "UNKNOWN"
                    ]
                  },
                  "goodValues": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "badValues": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "uncertainValues": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              },
              "deadband": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "absolute": {
                    "type": "number"
                  },
                  "percent": {
                    "type": "number",
                    "minimum": 0
                  }
                }
              },
              "heartbeatPolicy": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "heartbeatRequired": {
                    "type": "boolean"
                  },
                  "maxSilenceMs": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          },
          "eventAlarmMapping": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "eventEnabled": {
                "type": "boolean"
              },
              "alarmEnabled": {
                "type": "boolean"
              },
              "severitySource": {
                "type": "string",
                "enum": [
                  "RAW_PRIORITY",
                  "RAW_ALARM_CLASS",
                  "STATIC",
                  "RULE",
                  "UNKNOWN"
                ]
              },
              "defaultSeverity": {
                "type": "string",
                "enum": [
                  "CRITICAL",
                  "HIGH",
                  "MEDIUM",
                  "LOW",
                  "INFO",
                  "UNKNOWN"
                ]
              },
              "alarmCode": {
                "type": "string"
              },
              "alarmMessageTemplate": {
                "type": "string"
              }
            }
          },
          "location": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "locationRef": {
                "type": "string"
              },
              "terminal": {
                "type": "string"
              },
              "building": {
                "type": "string"
              },
              "level": {
                "type": "string"
              },
              "room": {
                "type": "string"
              },
              "zone": {
                "type": "string"
              }
            }
          },
          "hmiLocator": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "hmiLocatorAvailable": {
                "type": "boolean"
              },
              "drawingRef": {
                "type": "string"
              },
              "symbolRef": {
                "type": "string"
              },
              "pageRef": {
                "type": "string"
              },
              "coordinateRef": {
                "type": "string"
              }
            }
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "mappingReviewStatus",
              "reviewed"
            ],
            "properties": {
              "mappingReviewStatus": {
                "type": "string",
                "enum": [
                  "NOT_REVIEWED",
                  "UNDER_REVIEW",
                  "NEEDS_CLEANUP",
                  "ACCEPTED",
                  "REJECTED",
                  "BLOCKED",
                  "UNKNOWN"
                ]
              },
              "reviewed": {
                "type": "boolean"
              },
              "reviewerRef": {
                "type": "string"
              },
              "reviewedAt": {
                "type": "string",
                "format": "date-time"
              },
              "reviewNotes": {
                "type": "string"
              }
            }
          },
          "boundary": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "contractOnly",
              "runtimeMappingApplied",
              "edgeRuntimeEnabled",
              "linkProductionDeliveryAllowed",
              "directUfmsDbAccessAllowed",
              "writebackAllowed",
              "consumerImplementationIncluded"
            ],
            "properties": {
              "contractOnly": {
                "type": "boolean",
                "const": true
              },
              "runtimeMappingApplied": {
                "type": "boolean",
                "const": false
              },
              "edgeRuntimeEnabled": {
                "type": "boolean",
                "const": false
              },
              "linkProductionDeliveryAllowed": {
                "type": "boolean",
                "const": false
              },
              "directUfmsDbAccessAllowed": {
                "type": "boolean",
                "const": false
              },
              "writebackAllowed": {
                "type": "boolean",
                "const": false
              },
              "consumerImplementationIncluded": {
                "type": "boolean",
                "const": false
              }
            }
          }
        }
      }
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "evidenceId",
          "evidenceType"
        ],
        "properties": {
          "evidenceId": {
            "type": "string",
            "minLength": 1
          },
          "evidenceType": {
            "type": "string",
            "enum": [
              "tag_list",
              "asset_list",
              "sample_data",
              "hmi_reference",
              "normalization_rule",
              "mapping_review",
              "commissioning_note",
              "unknown"
            ]
          },
          "sourcePath": {
            "type": "string"
          },
          "hash": {
            "type": "string"
          }
        }
      },
      "default": []
    },
    "boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractOnly",
        "runtimeMappingApplied",
        "edgeRuntimeEnabled",
        "linkProductionDeliveryAllowed",
        "directUfmsDbAccessAllowed",
        "writebackAllowed",
        "consumerImplementationIncluded"
      ],
      "properties": {
        "contractOnly": {
          "type": "boolean",
          "const": true
        },
        "runtimeMappingApplied": {
          "type": "boolean",
          "const": false
        },
        "edgeRuntimeEnabled": {
          "type": "boolean",
          "const": false
        },
        "linkProductionDeliveryAllowed": {
          "type": "boolean",
          "const": false
        },
        "directUfmsDbAccessAllowed": {
          "type": "boolean",
          "const": false
        },
        "writebackAllowed": {
          "type": "boolean",
          "const": false
        },
        "consumerImplementationIncluded": {
          "type": "boolean",
          "const": false
        }
      }
    }
  }
}
