{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vantaris.local/contracts/schemas/event-v1.schema.json",
  "title": "EventV1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schemaVersion",
    "eventId",
    "eventType",
    "sourceTimestamp",
    "observedTimestamp",
    "severity",
    "status",
    "traceContext",
    "idempotencyKey"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "eventId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/eventId"
    },
    "tenantId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/tenantId"
    },
    "siteId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/siteId"
    },
    "gatewayId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/gatewayId"
    },
    "connectorId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/connectorId"
    },
    "sourceSystemId": {
      "$ref": "common-identifiers-v1.schema.json#/$defs/sourceSystemId"
    },
    "status": {
      "type": "string"
    },
    "createdAt": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/createdAt"
    },
    "updatedAt": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/updatedAt"
    },
    "traceContext": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/traceContext"
    },
    "correlationId": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/correlationId"
    },
    "idempotencyKey": {
      "$ref": "common-trace-context-v1.schema.json#/$defs/idempotencyKey"
    },
    "eventType": {
      "type": "string"
    },
    "sourceTimestamp": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/sourceTimestamp"
    },
    "observedTimestamp": {
      "$ref": "common-audit-fields-v1.schema.json#/$defs/observedTimestamp"
    },
    "severity": {
      "type": "string"
    }
  }
}
